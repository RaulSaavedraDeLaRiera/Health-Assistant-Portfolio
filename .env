# Configure your environment variables here

PORT=8080
LANGUAGE=EN
DISABLE_AUTH=TRUE

# Configurable limits
# Recommendations: default number of items when not specified; cap = max allowed.
RECOMMENDATIONS_DEFAULT_ITEMS=5
RECOMMENDATIONS_TOOL_LIMIT=10

# Health stats: default period when user says "my stats" without days; max period allowed (last X days).
HEALTH_STATS_DEFAULT_DAYS=7
HEALTH_STATS_MAX_DAYS=90

# Diet summary: default and max period; max rows in breakdown to limit response size.
DIET_SUMMARY_DEFAULT_DAYS=7
DIET_SUMMARY_MAX_DAYS=90
DIET_SUMMARY_BREAKDOWN_MAX_DAYS=7

# Vertex / ADK configuration
# REASONING_ENGINE_NAME=projects/YOUR_PROJECT/locations/europe-west1/reasoningEngines/YOUR_ID
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=europe-west1
# ADK_INTERNAL_PORT=9000
# ADK_APP_NAME=orchestrator
